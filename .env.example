# TSE provider: fiskaltrust (local Middleware + Swissbit stick) | fiskaly (cloud) | mock
# If unset: fiskaly when all FISKALY_* are set, otherwise mock.
TSE_PROVIDER=

# --- fiskaltrust Middleware (local Launcher) — required when TSE_PROVIDER=fiskaltrust ---
# Queue REST endpoint from the Portal, with rest:// swapped for http://
#   e.g. http://localhost:1500/<queueId>
FISKALTRUST_QUEUE_URL=
FISKALTRUST_CASHBOX_ID=
FISKALTRUST_QUEUE_ID=
# Stable GUID identifying this POS system (required by the middleware on every receipt)
FISKALTRUST_POS_SYSTEM_ID=
# Terminal/till id printed on receipts (defaults to "1" if unset)
FISKALTRUST_TERMINAL_ID=1

# --- Fiskaly KassenSichV (cloud) — leave all unset to run in mock mode ---
# Run scripts/fiskaly-setup.ts once to initialize the TSS and get FISKALY_CLIENT_ID
FISKALY_API_KEY=
FISKALY_API_SECRET=
FISKALY_TSS_ID=
FISKALY_ADMIN_PUK=
FISKALY_CLIENT_ID=

PORT=3000

# One-way DB snapshot sync to a second machine over Tailscale (Taildrop).
# After every backup (shift close + safety loop) the consistent snapshot is
# pushed to this tailnet machine as downtown-latest.db. Leave unset to disable.
#   e.g. TAILSCALE_SYNC_TARGET=pcx0118
TAILSCALE_SYNC_TARGET=

# Token guarding the on-demand DB pull endpoint (GET /api/export/snapshot),
# which streams a fresh consistent snapshot so another machine can pull the DB
# over Tailscale. Unset disables the endpoint. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
SNAPSHOT_TOKEN=
