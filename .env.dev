# Dev-only environment. Loaded by `npm run dev --workspace=server`.
# Keeps dev on its own port AND its own database so it can never collide
# with — or corrupt — the live production app (pm2, port 3001, downtown.db).
PORT=3000
DB_FILE=downtown.dev.db

# TSE left on mock in dev (never hit a real TSE — cloud or local stick — from dev).
# Set TSE_PROVIDER=fiskaltrust + FISKALTRUST_* here only to test against a real
# Launcher, or point them at scripts/fiskaltrust-stub.ts for a fake one.
TSE_PROVIDER=mock

# No DB sync from dev — only the live bar PC pushes snapshots to the Mac.
TAILSCALE_SYNC_TARGET=

# On-demand DB pull endpoint disabled in dev (unset → GET /api/export/snapshot 503s).
SNAPSHOT_TOKEN=

# Fiskaly left unset → mock TSE mode.
FISKALY_TSS_ID=
FISKALY_ADMIN_PUK=
FISKALY_CLIENT_ID=
