# Dev-only environment. Loaded by `npm run dev --workspace=server`.
# Keeps dev on its own port AND its own database so it can never collide
# with — or corrupt — the live production app (pm2, port 3001, downtown.db).
PORT=3000
DB_FILE=downtown.dev.db

# Fiskaly left unset → mock TSE mode (never hit the real TSE from dev).
FISKALY_TSS_ID=
FISKALY_ADMIN_PUK=
FISKALY_CLIENT_ID=
